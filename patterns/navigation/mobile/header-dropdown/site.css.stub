.nav-mobile__head{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem}.nav-mobile nav{display:grid;gap:.25rem}.nav-mobile nav a{padding:.8rem 0}.nav-mobile__cta{display:flex;justify-content:center;margin-top:2rem;padding:.9rem;background:var(--site-color-accent);color:var(--site-color-accent-contrast)}@media(min-width:64rem){.nav-mobile{display:none!important}}@media(prefers-reduced-motion:reduce){.nav-mobile__panel{transition:none!important}}.nav-mobile{position:fixed;inset:0;z-index:60}.nav-mobile__backdrop{position:absolute;inset:0;background:#0004}.nav-mobile__panel{position:absolute;inset:4.5rem 0 auto;padding:1rem 1.5rem;border-block:1px solid var(--site-color-border);background:var(--site-color-page);transform:translateY(-110%);transition:transform .2s}.nav-mobile.is-open .nav-mobile__panel{transform:none}
