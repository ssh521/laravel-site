.nav-mobile__head{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem}.nav-mobile nav{display:grid;gap:.25rem}.nav-mobile nav a{padding:.8rem 0}.nav-mobile__cta{display:flex;justify-content:center;margin-top:2rem;padding:.9rem;background:var(--site-color-accent);color:var(--site-color-accent-contrast)}@media(min-width:64rem){.nav-mobile{display:none!important}}@media(prefers-reduced-motion:reduce){.nav-mobile__panel{transition:none!important}}.nav-mobile{position:fixed;inset:0;z-index:60;pointer-events:none}.nav-mobile__backdrop{display:none}.nav-mobile__panel{position:absolute;inset:0 auto 0 0;width:min(82vw,20rem);padding:1.5rem;background:var(--site-color-page);transform:translateX(-100%);transition:transform .28s;pointer-events:auto}.nav-mobile.is-open .nav-mobile__panel{transform:none}body.nav-push-open [data-site-content]{transform:translateX(min(82vw,20rem))}
