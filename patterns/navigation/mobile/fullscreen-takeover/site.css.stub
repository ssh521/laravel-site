.nav-mobile__head{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem}.nav-mobile nav{display:grid;gap:.25rem}.nav-mobile nav a{padding:.8rem 0}.nav-mobile__cta{display:flex;justify-content:center;margin-top:2rem;padding:.9rem;background:var(--site-color-accent);color:var(--site-color-accent-contrast)}@media(min-width:64rem){.nav-mobile{display:none!important}}@media(prefers-reduced-motion:reduce){.nav-mobile__panel{transition:none!important}}.nav-mobile{position:fixed;inset:0;z-index:60;background:var(--site-color-page)}.nav-mobile__backdrop{display:none}.nav-mobile__panel{min-height:100%;padding:1.5rem;opacity:0;transition:opacity .25s}.nav-mobile.is-open .nav-mobile__panel{opacity:1}.nav-mobile nav a{display:block;font-size:clamp(2.25rem,12vw,5rem);font-weight:800;line-height:1.05}
