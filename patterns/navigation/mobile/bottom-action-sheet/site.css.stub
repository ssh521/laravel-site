.nav-mobile-action-sheet{position:fixed;inset:0;z-index:70}.nav-mobile-action-sheet__backdrop{position:absolute;inset:0;width:100%;background:rgb(28 32 35/.46)}.nav-mobile-action-sheet__panel{position:absolute;inset:auto 0 0;display:flex;max-height:min(82dvh,42rem);flex-direction:column;padding:1.25rem 1rem calc(1rem + env(safe-area-inset-bottom));border-radius:1.5rem 1.5rem 0 0;background:var(--site-color-surface);transform:translateY(100%);transition:transform .28s cubic-bezier(.16,1,.3,1)}.nav-mobile-action-sheet.is-open .nav-mobile-action-sheet__panel{transform:none}.nav-mobile-action-sheet__head{display:flex;align-items:center;justify-content:space-between;padding:.35rem .25rem 1rem}.nav-mobile-action-sheet nav{display:grid;gap:.35rem}.nav-mobile-action-sheet nav a{padding:.9rem .25rem;border-bottom:1px solid var(--site-color-border);font-weight:800}.nav-mobile-action-sheet__cta,.nav-mobile-sticky-action{padding:1rem;border-radius:.75rem;background:var(--site-color-accent);color:var(--site-color-accent-contrast);text-align:center;font-weight:800}.nav-mobile-action-sheet__cta{margin-top:1rem}.nav-mobile-sticky-action{position:fixed;inset:auto 1rem calc(1rem + env(safe-area-inset-bottom));z-index:45}@media(min-width:48rem){.nav-mobile-action-sheet,.nav-mobile-sticky-action{display:none!important}}@media(prefers-reduced-motion:reduce){.nav-mobile-action-sheet__panel{transition:none}}
