const trigger=document.querySelector('[data-site-menu-button]');const root=document.querySelector('[data-mobile-nav-root]');if(trigger&&root){let previous;let timer;const panel=root.querySelector('[data-nav-panel]');const focusable=()=>[...panel.querySelectorAll('a[href],button:not([disabled])')].filter(element=>element.offsetParent!==null);const close=()=>{clearTimeout(timer);root.classList.remove('is-open');trigger.setAttribute('aria-expanded','false');document.body.style.overflow='';timer=setTimeout(()=>{root.hidden=true;(previous||trigger).focus()},matchMedia('(prefers-reduced-motion: reduce)').matches?0:280)};const open=()=>{clearTimeout(timer);previous=document.activeElement;root.hidden=false;requestAnimationFrame(()=>root.classList.add('is-open'));trigger.setAttribute('aria-expanded','true');document.body.style.overflow='hidden';focusable()[0]?.focus()};trigger.addEventListener('click',open);root.querySelectorAll('[data-nav-close],[data-nav-link]').forEach(element=>element.addEventListener('click',close));root.addEventListener('keydown',event=>{if(event.key==='Escape'){close();return}if(event.key!=='Tab')return;const items=focusable(),first=items[0],last=items.at(-1);if(event.shiftKey&&document.activeElement===first){event.preventDefault();last?.focus()}else if(!event.shiftKey&&document.activeElement===last){event.preventDefault();first?.focus()}})}
