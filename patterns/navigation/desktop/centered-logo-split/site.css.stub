.nav-centered{position:relative;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;min-height:5rem;padding-inline:max(1rem,calc((100vw - 80rem)/2));border-bottom:1px solid var(--site-color-border)}.nav-centered nav{display:flex;gap:1.75rem}.nav-centered nav:last-child{justify-content:flex-end}.nav-centered__brand{justify-self:center}@media(max-width:63.99rem){.nav-centered nav{display:none}.nav-centered{grid-template-columns:1fr}}
