.nav-offcanvas-bar{position:absolute;inset:0 0 auto;z-index:40;display:flex;align-items:center;justify-content:space-between;min-height:5rem;padding-inline:max(1rem,calc((100vw - 80rem)/2))}.nav-offcanvas{position:fixed;inset:0;z-index:60;display:grid;place-items:center;background:var(--site-color-page);padding:2rem}.nav-offcanvas[hidden]{display:none}.nav-offcanvas>button{position:absolute;top:2rem;right:2rem}.nav-offcanvas nav{display:grid;gap:.5rem;text-align:center}.nav-offcanvas nav a{font-size:clamp(2.5rem,7vw,7rem);font-weight:800;line-height:1}
