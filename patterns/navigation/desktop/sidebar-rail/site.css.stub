.nav-rail{position:fixed;inset:0 auto 0 0;z-index:40;display:flex;width:13rem;flex-direction:column;padding:2rem 1.5rem;border-right:1px solid var(--site-color-border);background:var(--site-color-page)}.nav-rail nav{display:grid;gap:.25rem;margin-block:auto}.nav-rail nav a{padding-block:.55rem}.nav-rail+main{margin-left:13rem}@media(max-width:63.99rem){.nav-rail{position:static;width:auto;min-height:4.5rem;flex-direction:row;align-items:center;justify-content:space-between}.nav-rail nav,.nav-rail>a:last-child{display:none}.nav-rail+main{margin-left:0}}
