.nav-overlay{position:fixed;inset:0 0 auto;z-index:40;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:2rem;min-height:5rem;padding-inline:max(1rem,calc((100vw - 80rem)/2));color:#fff;transition:background-color .25s,color .25s,border-color .25s}.nav-overlay nav{display:flex;justify-content:center;gap:1.5rem}.nav-overlay.is-scrolled{color:var(--site-color-text);background:color-mix(in srgb,var(--site-color-page) 94%,transparent);border-bottom:1px solid var(--site-color-border);backdrop-filter:blur(16px)}@media(max-width:63.99rem){.nav-overlay nav,.nav-overlay>a:last-child{display:none}}
