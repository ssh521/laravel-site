.nav-compact-floating{position:fixed;inset:.75rem 0 auto;z-index:50;padding-inline:1rem}.nav-compact-floating__inner{display:grid;min-height:4.5rem;max-width:74rem;margin-inline:auto;grid-template-columns:auto 1fr auto;align-items:center;gap:1.5rem;padding:.65rem .75rem .65rem 1rem;border:1px solid var(--site-color-border);border-radius:1.5rem;background:color-mix(in srgb,var(--site-color-surface) 90%,transparent);box-shadow:0 16px 48px rgb(28 32 35/.08);backdrop-filter:blur(18px)}.nav-compact-floating nav{display:none;justify-content:center;gap:1.4rem;white-space:nowrap;font-size:.82rem;font-weight:700}.nav-compact-floating__cta{display:none}.nav-compact-floating__menu{justify-self:end;min-height:2.75rem;padding-inline:.85rem;border:1px solid var(--site-color-border);border-radius:.75rem;font-weight:800}@media(min-width:64rem){.nav-compact-floating nav{display:flex}.nav-compact-floating__cta{display:inline-flex}.nav-compact-floating__menu{display:none}}
