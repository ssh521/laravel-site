.nav-corporate{border-bottom:1px solid var(--site-color-border)}.nav-corporate__utility,.nav-corporate__primary{display:grid;grid-template-columns:auto 1fr auto;align-items:center;padding-inline:max(1rem,calc((100vw - 80rem)/2))}.nav-corporate__utility{min-height:2rem;background:var(--site-color-surface-muted);font-size:.75rem}.nav-corporate__primary{min-height:4.75rem;gap:2rem}.nav-corporate nav{display:flex;justify-content:flex-end;gap:1.5rem;white-space:nowrap}@media(max-width:63.99rem){.nav-corporate__utility,.nav-corporate__primary nav,.nav-corporate__primary>a:last-child{display:none}.nav-corporate__primary{display:flex}}
