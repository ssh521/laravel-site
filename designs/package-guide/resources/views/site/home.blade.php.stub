        class="bg-(--site-color-surface)"
    >
        <div class="divide-y divide-(--site-color-border) border-y border-(--site-color-border)">
            <a href="#extend" class="group grid gap-3 py-5 text-(--site-color-text) transition hover:text-(--site-color-accent) md:grid-cols-[0.25fr_1fr_0.7fr] md:items-center">
