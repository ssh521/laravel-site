        <div class="mt-10 divide-y divide-(--site-color-border) border-y border-(--site-color-border)">
            @foreach ([
                ['name' => 'essential', 'label' => '범용 회사/서비스 소개'],
                ['name' => 'conversion', 'label' => '광고 유입/문의 전환'],
                ['name' => 'corporate-trust', 'label' => 'B2B 회사/전문 서비스'],
                ['name' => 'local-business', 'label' => '오프라인 매장'],
