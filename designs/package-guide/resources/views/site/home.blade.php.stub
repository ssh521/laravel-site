    <x-site.section
        id="packages"
        eyebrow="Package Stack"
        title="공개 사이트를 만든 뒤 관리자와 기능 패키지로 확장합니다"
        description="laravel-site는 방문자용 첫 화면을 담당합니다. 운영 화면과 콘텐츠 기능은 laravel-admin과 기능 패키지를 이어서 설치해 확장합니다."
    >
        <div class="grid min-w-0 gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
            <div class="grid min-w-0 gap-4 sm:grid-cols-2">
                <x-site.feature-card title="ssh521/laravel-admin" description="관리자 레이아웃, 메뉴, 권한 기반을 추가합니다." />
                <x-site.feature-card title="admin-users / file" description="관리자 사용자 관리와 파일 관리 기능을 얹습니다." />
                <x-site.feature-card title="blog / bbs / page" description="블로그, 게시판, 페이지 CMS로 콘텐츠 운영을 확장합니다." />
                <x-site.feature-card title="popup / notification" description="팝업, 배너, 공지바, 알림 기능을 운영 화면에 연결합니다." />
            </div>

            <div class="min-w-0 rounded-none border border-(--site-color-border) bg-(--site-color-code) p-6 text-sm text-(--site-color-text) shadow-sm">
                <pre class="overflow-x-auto leading-7"><code># 1. 공개 사이트
composer require ssh521/laravel-site
php artisan laravel-site:install

# 2. 관리자 기반
composer require ssh521/laravel-admin
php artisan laravel-admin:install

# 3. 자주 쓰는 관리자 기능 패키지
composer require ssh521/laravel-admin-users ssh521/laravel-file
php artisan laravel-admin:install --with=users,file

# 4. 콘텐츠 기능 패키지 예시
composer require ssh521/laravel-blog ssh521/laravel-bbs
php artisan laravel-admin:install --with=blog,bbs</code></pre>
            </div>
        </div>
    </x-site.section>

    <x-site.section id="designs" eyebrow="Design Library" title="목적별 디자인으로 바로 교체">
