>
    <section id="overview" class="site-agency-hero relative overflow-hidden border-b border-(--site-color-border)">
        <div class="site-agency-field" aria-hidden="true"></div>

        <div class="relative mx-auto flex min-h-[calc(100dvh-4rem)] max-w-7xl flex-col justify-end px-4 pb-10 pt-20 sm:px-6 lg:px-8 lg:pb-12">
            <div class="mb-10 flex justify-center lg:mb-12">
                <div class="site-orbit" aria-hidden="true">
                    <span></span>
                </div>
            </div>

            <div class="max-w-6xl">
                <p class="site-kicker flex items-center gap-4 text-xs font-semibold uppercase text-(--site-color-accent)">
                    <span class="h-px w-14 bg-(--site-color-accent)"></span>
                    ssh521 package guide
                </p>

                <h1 class="mt-6 text-5xl font-black uppercase leading-none text-(--site-color-text) sm:text-7xl lg:text-7xl">
                    Laravel Starter Kit 위에
                    <span class="site-gradient-text block">Public Site</span>
                    <span class="site-outline-text block">Scaffold</span>
