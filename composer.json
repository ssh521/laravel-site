{
    "name": "ssh521/laravel-site",
    "description": "Responsive public site starter scaffold for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "ssh521"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/filesystem": "^13.0",
        "livewire/livewire": "^3.0|^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ssh521\\LaravelSite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ssh521\\LaravelSite\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml.dist"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ssh521\\LaravelSite\\LaravelSiteServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
